    "clsx": "^2.1.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "radix-ui": "^1.4.3",
