generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppRole {
  ADMIN
  EDITOR
  APPROVER
  TRANSLATION_APPROVER
}

enum UpstreamSystem {
  GOOGLE_SHEETS
}

enum OrchestratorType {
  ZAPIER
  N8N
  MANUAL
}

enum DriveImportBatchStatus {
  STAGED
  PARTIALLY_SENT
  SENT_TO_QUEUE
  NEEDS_REIMPORT_DECISION
  FAILED
}

enum DriveSpreadsheetState {
  STAGED
  PARTIALLY_SENT
  SENT_TO_QUEUE
  NEEDS_REIMPORT_DECISION
}

enum DriveSpreadsheetRowState {
  STAGED
  QUEUE_PENDING
  QUEUED
  UPDATED
  REPLACED
  KEPT_AS_IS
  DUPLICATE
  CONFLICT
  SKIPPED
  REJECTED
  PUBLISHED_COMPLETE
}

enum DriveConflictConfidence {
  HIGH_CONFIDENCE_DUPLICATE
  POSSIBLE_DUPLICATE
  NO_MEANINGFUL_MATCH
}

enum DriveReimportStrategy {
  UPDATE
  REPLACE
  KEEP_AS_IS
}

enum ImportMode {
  PREVIEW
  COMMIT
}

enum ImportReceiptStatus {
  RECEIVED
  PROCESSED
  DUPLICATE
  REJECTED
  FAILED
}

enum ContentProfile {
  YANN
  YURI
  SHAWN
  SOPHIAN_YACINE
  ZAZMIC_PAGE
}

enum ContentType {
  STATIC_POST
  CAROUSEL
}

enum ContentStatus {
  // ── Legacy states (kept for existing data) ─────────────────────────────
  IMPORTED
  IN_REVIEW
  CONTENT_APPROVED
  DESIGN_REQUESTED
  DESIGN_IN_PROGRESS
  // ── Active states ──────────────────────────────────────────────────────
  CHANGES_REQUESTED
  DESIGN_FAILED
  DESIGN_READY
  DESIGN_APPROVED
  TRANSLATION_APPROVED
  // ── New intake ─────────────────────────────────────────────────────────
  BLOCKED
  WAITING_FOR_COPY
  READY_FOR_DESIGN
  // ── New design ─────────────────────────────────────────────────────────
  IN_DESIGN
  // ── New translation ────────────────────────────────────────────────────
  TRANSLATION_PENDING
  TRANSLATION_REQUESTED
  TRANSLATION_READY
  // ── New review + post ──────────────────────────────────────────────────
  READY_FOR_FINAL_REVIEW
  READY_TO_POST
  POSTED
  // ── Legacy post ────────────────────────────────────────────────────────
  READY_TO_PUBLISH
  PUBLISHED_MANUALLY
}

enum NoteType {
  COMMENT
  REVISION
}

enum ApprovalStage {
  PUBLISH
  TRANSLATION
}

enum ApprovalDecision {
  APPROVED
  CHANGES_REQUESTED
}

enum DesignProvider {
  CANVA
  GPT_IMAGE
  AI_VISUAL
  MANUAL
}

enum DesignRequestStatus {
  REQUESTED
  IN_PROGRESS
  READY
  APPROVED
  COMPLETED
  FAILED
  REJECTED
}

enum AssetType {
  STATIC_IMAGE
  CAROUSEL_SLIDE
  EXPORT_PACKAGE
  VIDEO
}

enum AssetStatus {
  DRAFT
  READY
  DELIVERED
}

enum TranslationStatus {
  NOT_REQUIRED
  REQUESTED
  READY_FOR_APPROVAL
  APPROVED
}

enum PublishLanguage {
  ENG
  PT_BR
  FR
}

enum WorksheetSelectionStrategy {
  EXPLICIT_WORKSHEET_ID
  EXACT_WORKSHEET_NAME
  MONTHLY_TAB_PATTERN
}

enum TitleDerivationStrategy {
  EXPLICIT_MAPPED_FIELD
  PROFILE_FALLBACK_FIELD
  HEURISTIC_LAST_RESORT
}

enum PublishAttemptMode {
  MOCK
  LINKEDIN_API
}

enum PublishAttemptStatus {
  DRAFT
  CONFIRMED
  POSTED
  FAILED
}

model User {
  id        String          @id @default(cuid())
  email     String          @unique
  name      String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  roles     UserRole[]
  notes     WorkflowNote[]
  approvals ApprovalRecord[]
  imports   ImportReceipt[] @relation("ImportedByUser")
  driveImports SpreadsheetImportBatch[] @relation("ImportedDriveBatch")
  googleConnection GoogleConnection?
}

model GoogleConnection {
  id                   String   @id @default(cuid())
  userId               String   @unique
  googleSub            String   @unique
  googleEmail          String
  /// Deprecated: use accessTokenEncrypted.
  accessToken          String   @db.Text
  accessTokenEncrypted String?  @db.Text
  /// Deprecated: use refreshTokenEncrypted.
  refreshToken         String?  @db.Text
  refreshTokenEncrypted String?  @db.Text
  encryptionVersion    Int      @default(1)
  scope                String?  @db.Text
  expiresAt            DateTime?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([googleEmail])
  @@index([active])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      AppRole
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model ContentItem {
  id                  String            @id @default(cuid())
  canonicalKey        String            @unique
  profile             ContentProfile
  contentType         ContentType
  title               String
  copy                String            @db.Text
  translationCopy     String?           @db.Text
  translationRequestedAt DateTime?
  translationGeneratedAt DateTime?
  sourceLocale        String            @default("en")
  translationStatus   TranslationStatus @default(NOT_REQUIRED)
  translationRequired Boolean           @default(false)
  // ── Per-language translation (Phase 1) ───────────────────────────────────
  translationPtBrCopy        String?           @db.Text
  translationPtBrStatus      TranslationStatus @default(NOT_REQUIRED)
  translationPtBrRequestedAt DateTime?
  translationPtBrGeneratedAt DateTime?
  translationPtBrApprovedAt  DateTime?
  translationFrCopy          String?           @db.Text
  translationFrStatus        TranslationStatus @default(NOT_REQUIRED)
  translationFrRequestedAt   DateTime?
  translationFrGeneratedAt   DateTime?
  translationFrApprovedAt    DateTime?
  selectedPublishLanguage    PublishLanguage?
  preferredDesignProvider DesignProvider?
  autopostEnabled     Boolean           @default(false)
  currentStatus       ContentStatus     @default(IMPORTED)
  planningSnapshot    Json
  latestImportAt      DateTime?
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  sourceLinks         ContentSourceLink[]
  importReceipts      ImportReceipt[]
  notes               WorkflowNote[]
  approvals           ApprovalRecord[]
  statusEvents        StatusEvent[]
  designRequests      DesignRequest[]
  assets              ContentAsset[]
  publishAttempts     PublishAttempt[]
}

model ContentSourceLink {
  id              String         @id @default(cuid())
  contentItemId   String
  upstreamSystem  UpstreamSystem
  sheetProfileKey String?
  sheetProfileVersion Int?
  spreadsheetId   String
  worksheetId     String
  worksheetName   String
  rowId           String
  rowNumber       Int?
  rowVersion      String?
  lastFingerprint String?
  pushbackEnabled Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contentItem     ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([upstreamSystem, spreadsheetId, worksheetId, rowId])
}

model ImportReceipt {
  id             String              @id @default(cuid())
  idempotencyKey String
  mode           ImportMode          @default(COMMIT)
  orchestrator   OrchestratorType
  upstreamSystem UpstreamSystem
  sheetProfileKey String?
  sheetProfileVersion Int?
  status         ImportReceiptStatus @default(RECEIVED)
  payloadVersion Int
  fingerprint    String
  payload        Json
  contentItemId  String?
  importedById   String?
  errorCode      String?
  errorMessage   String?
  receivedAt     DateTime            @default(now())
  processedAt    DateTime?
  contentItem    ContentItem?        @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  importedBy     User?               @relation("ImportedByUser", fields: [importedById], references: [id], onDelete: SetNull)

  @@unique([idempotencyKey, mode])
}

model WorkflowNote {
  id            String      @id @default(cuid())
  contentItemId String
  authorId      String
  type          NoteType
  body          String      @db.Text
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  author        User        @relation(fields: [authorId], references: [id], onDelete: Restrict)
}

model ApprovalRecord {
  id            String           @id @default(cuid())
  contentItemId String
  actorId       String
  stage         ApprovalStage
  decision      ApprovalDecision
  note          String?          @db.Text
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  contentItem   ContentItem      @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  actor         User             @relation(fields: [actorId], references: [id], onDelete: Restrict)
}

model StatusEvent {
  id            String        @id @default(cuid())
  contentItemId String
  fromStatus    ContentStatus?
  toStatus      ContentStatus
  actorEmail    String?
  note          String?       @db.Text
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  contentItem   ContentItem   @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
}

model ProfileTemplateMapping {
  id                 String         @id @default(cuid())
  profile            ContentProfile
  contentType        ContentType
  locale             String         @default("en")
  designProvider     DesignProvider @default(CANVA)
  externalTemplateId String
  displayName        String
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  designRequests     DesignRequest[]

  @@unique([profile, contentType, locale, designProvider, externalTemplateId])
}

model DesignRequest {
  id                String                 @id @default(cuid())
  contentItemId     String
  profileMappingId  String?
  designProvider    DesignProvider
  requestFingerprint String
  attemptNumber     Int                    @default(1)
  status            DesignRequestStatus   @default(REQUESTED)
  externalRequestId String?
  errorCode         String?
  errorMessage      String?
  requestPayload    Json?
  resultPayload     Json?
  deletedAt         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  contentItem       ContentItem            @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  profileMapping    ProfileTemplateMapping? @relation(fields: [profileMappingId], references: [id], onDelete: SetNull)
  assets            ContentAsset[]

  @@unique([contentItemId, requestFingerprint, attemptNumber])
}

model ContentAsset {
  id              String         @id @default(cuid())
  contentItemId   String
  designRequestId String?
  assetType       AssetType
  assetStatus     AssetStatus    @default(DRAFT)
  locale          String         @default("en")
  slideIndex      Int?
  externalUrl     String?
  storagePath     String?
  metadata        Json?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contentItem     ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  designRequest   DesignRequest? @relation(fields: [designRequestId], references: [id], onDelete: SetNull)
}

model SpreadsheetImportBatch {
  id                     String                 @id @default(cuid())
  importedById           String?
  driveFileId            String
  spreadsheetId          String
  spreadsheetName        String
  folderName             String
  owner                  String
  sourceGroup            String
  lastUpdatedAt          DateTime?
  reimportStrategy       DriveReimportStrategy   @default(UPDATE)
  status                 DriveImportBatchStatus   @default(STAGED)
  scanFingerprint        String
  sourceContext          Json
  pipelineSignals        Json
  validWorksheetCount    Int                    @default(0)
  detectedRowCount       Int                    @default(0)
  qualifiedRowCount      Int                    @default(0)
  importedRowCount       Int                    @default(0)
  updatedRowCount        Int                    @default(0)
  replacedRowCount       Int                    @default(0)
  keptRowCount           Int                    @default(0)
  conflictCount          Int                    @default(0)
  alreadyPublishedRowCount Int                  @default(0)
  stagedAt               DateTime               @default(now())
  queuedAt               DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  importedBy             User?                  @relation("ImportedDriveBatch", fields: [importedById], references: [id], onDelete: SetNull)
  rows                   SpreadsheetImportRow[]

  @@index([spreadsheetId])
  @@index([status, stagedAt])
}

model SpreadsheetImportRow {
  id                     String                   @id @default(cuid())
  batchId                String
  worksheetId            String
  worksheetName          String
  rowId                  String
  rowNumber              Int?
  rowVersion             String?
  rowKind                String                   @default("DATA")
  rowStatus              DriveSpreadsheetRowState @default(STAGED)
  conflictConfidence     DriveConflictConfidence   @default(NO_MEANINGFUL_MATCH)
  conflictAction         DriveReimportStrategy?
  existingContentItemId  String?
  contentItemId          String?
  title                  String
  idea                   String?
  copy                   String                   @db.Text
  translationDraft       String?                  @db.Text
  plannedDate            String?
  publishedFlag          String?
  publishedPostUrl       String?
  sourceAssetLink        String?
  translationRequired    Boolean                  @default(false)
  autoPostEnabled        Boolean                  @default(false)
  preferredDesignProvider DesignProvider?
  matchSignals           Json
  rowPayload             Json
  normalizedPayload      Json?
  conflictSuggestion     Json?
  reason                 String?                  @db.Text
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  batch                  SpreadsheetImportBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowId])
  @@index([batchId, rowStatus])
}

model PublishAttempt {
  id                      String               @id @default(cuid())
  contentItemId           String
  contentItem             ContentItem          @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  mode                    PublishAttemptMode
  status                  PublishAttemptStatus
  targetOwnerName         String
  targetLabel             String
  targetType              String
  targetConnectionStatus  String
  selectedPublishLanguage PublishLanguage
  copySnapshot            String               @db.Text
  assetType               AssetType?
  assetUrl                String?              @db.Text
  assetSnapshot           Json?
  linkedinPostUrn         String?
  linkedinPostUrl         String?
  createdById             String?
  confirmedAt             DateTime?
  postedAt                DateTime?
  errorMessage            String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([contentItemId])
  @@index([mode, status])
}
